#!/bin/sh
# .githooks/prepare-commit-msg
# 偵測暫存的 .bytes 檔案，產生差異摘要
# 安裝：git config core.hooksPath .githooks
#
# ── 切換模式 ──────────────────────────────────────────
# MODE=B  差異寫入 commit 訊息視窗（預設）
# MODE=A  差異寫入 .bytes_diff_preview.txt 並用記事本開啟
MODE=A
# ────────────────────────────────────────────────────

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"

# 跳過 merge / squash
case "$COMMIT_SOURCE" in
  merge|squash) exit 0 ;;
esac

# 找 Python（python 優先，fallback python3）
PYTHON=""
for cmd in python python3; do
  if command -v "$cmd" > /dev/null 2>&1; then
    PYTHON="$cmd"
    break
  fi
done
[ -z "$PYTHON" ] && exit 0

# Repo 根目錄
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
SCRIPT="$REPO_ROOT/tools/bytes_diff_summary.py"
[ -f "$SCRIPT" ] || exit 0

# 取得暫存中有異動的 .bytes 檔案
STAGED_FILES=$(git diff --cached --name-only --diff-filter=AM 2>/dev/null | grep '\.bytes$')
[ -z "$STAGED_FILES" ] && exit 0

# 產生摘要
SUMMARY=$("$PYTHON" "$SCRIPT" $STAGED_FILES 2>/dev/null)
[ -z "$SUMMARY" ] && exit 0

if [ "$MODE" = "A" ]; then
  # 模式 A：寫入預覽檔並開啟記事本
  PREVIEW_FILE="$REPO_ROOT/.bytes_diff_preview.txt"
  printf "%s\n" "$SUMMARY" | sed 's/^# *//' > "$PREVIEW_FILE"
  PREVIEW_WIN=$(cygpath -w "$PREVIEW_FILE" 2>/dev/null || echo "$PREVIEW_FILE")
  powershell.exe -Command "Start-Process '$PREVIEW_WIN'" 2>/dev/null &
else
  # 模式 B：去掉 # 前綴後寫入 commit 訊息（Fork 可見）
  printf "\n" >> "$COMMIT_MSG_FILE"
  printf "%s\n" "$SUMMARY" | sed 's/^# *//' >> "$COMMIT_MSG_FILE"
fi

exit 0
